<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Files</title>
</head>
<body>

    <h1>Your Files</h1>

    <% if (files && files.length > 0) { %>
        <ul>
            <% files.forEach(file => { %>
                <li>
                    <strong><%= file.filename %></strong><br>

                    Created at:
                    <%= file.createdAt 
                        ? new Date(file.createdAt).toLocaleString() 
                        : "N/A" %>
                    <br>

                    Size: <%= file.size %> bytes
                    <br>

                    <form action="/folder/delete/<%= file.id %>" method="POST">
                        <button>Delete</button>
                    </form>
                    <form action="/folder/download/<%= file.id %>" method="POST">
                        <button>Download</button>
                    </form>
                </li>
                <hr>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No files found.</p>
    <% } %>

</body>
</html>
